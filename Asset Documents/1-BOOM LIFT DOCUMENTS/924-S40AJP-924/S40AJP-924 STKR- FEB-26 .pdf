.emoji.apple { background-size: 100px 100px; }

.emojik.apple { background-size: 160px 160px; }

.emoji.apple.b151 { background-size: 80px 80px; }

.emojik.apple.b151 { background-size: 128px 128px; }

.emoji.wa { background-size: 100px 100px; }

.emojik.wa { background-size: 160px 160px; }

.emoji.wa.b147 { background-size: 80px 120px; }

.emojik.wa.b147 { background-size: 128px 192px; }

html, body, #app { width: 100%; height: 100%; padding: 0px; margin: 0px; ov=
erflow: hidden; }

#app { position: absolute; top: 0px; left: 0px; }

progress { appearance: none; width: 100%; margin: 0px; color: var(--progres=
s-primary); background-color: var(--progress-background); border: none; }

progress[value]::-webkit-progress-bar { background-color: var(--progress-ba=
ckground); }

progress[value]::-webkit-progress-value { background-color: var(--progress-=
primary); transition: width 0.45s; }

[role=3D"button"] { cursor: pointer; }

#main::after { display: none; }

#main::before { padding: 0px; }

.matched-text { font-weight: 700; color: var(--highlight); }

body.dark { color: var(--primary); background-color: var(--WDS-app-wash, va=
r(--app-background)); background-image: none; }

body.debug :not(path):not(g) { outline: solid 1px rgba(var(--primary-strong=
-rgb),.5) !important; }

body.e2e [data-testid]:hover { outline: solid 1px rgba(var(--primary-strong=
-rgb),.5) !important; }

body.e2e [data-testid]:hover::before { opacity: 1; }

body.e2e [data-testid]::before { content: attr(data-testid); color: var(--a=
pp-background); position: absolute; white-space: nowrap; z-index: var(--lay=
er-10); background-color: var(--primary-strong); border-radius: 5px; border=
: 1px solid var(--app-background); padding: 3px; font-size: 8pt; line-heigh=
t: 8px; pointer-events: none; left: 50%; top: 0px; transform: translate(-50=
%); width: max-content; height: max-content; transition: opacity 0.2s ease-=
in-out; opacity: 0; }

body.e2e [data-testrobot]:hover { outline: orangered dotted 2px !important;=
 }

body.e2e [data-testrobot]:hover::after { opacity: 1; }

body.e2e [data-testrobot]::after { content: attr(data-testrobot); color: va=
r(--app-background); position: absolute; white-space: nowrap; z-index: var(=
--layer-10); background-color: rgb(255, 69, 0); border-radius: 5px; border:=
 1px solid var(--app-background); padding: 3px; font-size: 8pt; line-height=
: 8px; pointer-events: none; left: 0px; top: 0px; transform: translate(0px)=
; width: max-content; height: max-content; transition: opacity 0.2s ease-in=
-out; opacity: 0; }

input[type=3D"text"]::-webkit-input-placeholder, input[type=3D"password"]::=
-webkit-input-placeholder { font-size: 15px; color: var(--input-placeholder=
); }

.os-mac input[type=3D"text"]::-webkit-input-placeholder, .os-mac input[type=
=3D"password"]::-webkit-input-placeholder { -webkit-font-smoothing: antiali=
ased; }

select { box-sizing: border-box; width: 100%; padding: 6px 36px 6px 4px; fo=
nt-size: 14px; line-height: 18px; color: var(--primary-stronger); backgroun=
d-color: transparent; border-top: none; border-right: none; border-left: no=
ne; border-image: initial; border-bottom: 1px solid var(--border-strong); b=
order-radius: 0px; outline: none; appearance: none; }

.dark select:focus { background-color: var(--panel-background); }

.emoji, .emojik { display: inline-block; vertical-align: top; zoom: 1; bord=
er: 0px; }

code .emoji { vertical-align: middle; }

.emoji { width: 20px; height: 20px; image-rendering: -webkit-optimize-contr=
ast; }

.emoji.apple { margin-right: 1px; margin-left: 1px; }

.emojik { width: 32px; height: 32px; image-rendering: -webkit-optimize-cont=
rast; }

.safari-fix .emoji, .safari-fix .emojik { image-rendering: unset; }

.overlay { position: fixed; top: 0px; left: 0px; box-sizing: border-box; wi=
dth: 100%; height: 100%; }

