@charset "utf-8";

._ak3k { position: relative; z-index: var(--layer-1); box-sizing: border-bo=
x; display: inline-block; flex: 0 0 auto; margin: 8px 5px 10px; overflow: h=
idden; vertical-align: middle; border: 1px solid var(--media-editor-thumb-b=
order); border-radius: 5px; }

._ak3k._ak3l { margin: 6px 3px 8px; border: 3px solid var(--media-editor-th=
umb-border-active); }

._ak3k:hover { cursor: pointer; }

.keyboard-user ._ak3k:focus { filter: brightness(0.7); }

._ak3i { position: relative; top: 0px; left: 0px; z-index: 2; width: 52px; =
height: 52px; }

._ak3i img { width: 100%; height: 100%; object-fit: cover; pointer-events: =
none; }

._ak3i._ak3j { background-repeat: no-repeat; background-position: center ce=
nter; background-size: 26px; }

._ak3i::before { position: absolute; top: 0px; right: 0px; width: 100%; hei=
ght: 40px; content: ""; background: linear-gradient(10deg,transparent 0%,tr=
